# Copy to .env and adjust for your environment.
# In development, /api requests are proxied to localhost:8000 by vite.config.ts.
# In production (Docker/nginx), leave VITE_API_BASE_URL empty and configure
# nginx to proxy /api/ to the backend container.

# Base URL for the tracer API.
# Empty string = use relative paths (works with the nginx proxy).
# Example for direct backend access: http://tracer-api:8000
VITE_API_BASE_URL=
