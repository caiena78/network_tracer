# .env.example — copy to .env in the STANDALONE ROOT folder, then edit
# All variables are prefixed with TRACER_

# ── NetBox ─────────────────────────────────────────────────────────────────────
TRACER_NETBOX_URL=https://netbox.example.com
TRACER_NETBOX_TOKEN=your_netbox_api_token_here
TRACER_NETBOX_VERIFY_SSL=true

# ── Device SSH credentials ──────────────────────────────────────────────────────
TRACER_DEVICE_USERNAME=admin
TRACER_DEVICE_PASSWORD=secret
TRACER_DEVICE_ENABLE_SECRET=
TRACER_DEVICE_TIMEOUT=30

# ── Vault (optional — leave blank to use the device credentials above) ──────────
TRACER_VAULT_ADDR="https://vault.lcmchealth.org:8200"
TRACER_VAULT_ROLE_ID="4ce0423d-5411-b0cf-fdc6-8c5b4ea98b63"
TRACER_VAULT_SECRET_ID="e72e2207-8da9-5415-b8b3-8f0c079a20e3"
TRACER_VAULT_MOUNT=secret
TRACER_VAULT_PATH=network/device

# ── Tracing engine path ───────────────────────────────────────────────────────────
# If network_tracer.py lives in a separate folder (e.g. a shared netbox_tools/
# directory), set this to its absolute path.  Leave blank to use auto-detection
# (looks for a sibling folder of web_path_tracer/ that contains network_tracer.py).
TRACER_TOOLS_PATH=

# ── API ──────────────────────────────────────────────────────────────────────────
TRACER_HOST=0.0.0.0
TRACER_PORT=8000
TRACER_RELOAD=false
# Comma-separated CORS origins — use * in development, restrict in production
TRACER_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Optional API key (leave blank to disable)
TRACER_API_KEY=

# ── Performance ──────────────────────────────────────────────────────────────────
TRACER_MAX_HOPS=30
TRACER_TRACE_TIMEOUT_SECONDS=300
TRACER_MAX_CONCURRENT_TRACES=10
TRACER_MAX_L3_BRANCH_WORKERS=6

# ── Caching ──────────────────────────────────────────────────────────────────────
TRACER_NETBOX_PREFIX_CACHE_TTL=300
TRACER_TRACE_RESULT_CACHE_TTL=600
TRACER_TASK_TTL_SECONDS=3600

# ── History persistence ────────────────────────────────────────────────────────
# Path to the SQLite history database (created automatically if it does not exist).
TRACER_HISTORY_DB_PATH=./trace_history.db
